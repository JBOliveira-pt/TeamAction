# Recommended for most uses
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://user:password@host:port/database?sslmode=require

# Parameters for constructing your own connection string
PGHOST=your-neon-host.eu-central-1.aws.neon.tech
PGHOST_UNPOOLED=your-neon-host.eu-central-1.aws.neon.tech
PGUSER=your_db_user
PGDATABASE=your_database_name
PGPASSWORD=your_secure_password

# Parameters for Vercel Postgres Templates
POSTGRES_URL=postgresql://user:password@host:port/database?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:port/database?sslmode=require
POSTGRES_USER=your_db_user
POSTGRES_HOST=your-neon-host.eu-central-1.aws.neon.tech
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DATABASE=your_database_name
POSTGRES_URL_NO_SSL=postgresql://user:password@host:port/database
POSTGRES_PRISMA_URL=postgresql://user:password@host:port/database?connect_timeout=15&sslmode=require

# My secret key genereted by: https://generate-secret.vercel.app/32
AUTH_SECRET=your_32_char_secret_key_here

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk Webhook Secret (get from Clerk Dashboard -> Webhooks)
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# CLOUDFLARE R2 CONFIGURATION -------------------------------------------
# Credenciais S3 geradas no painel do Cloudflare R2
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# O seu Account ID (encontrado no URL ou na página R2 do dashboard)
R2_ACCOUNT_ID=your_cloudflare_account_id

# Endpoint S3-Compatible do R2
# Formato: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your_public_bucket_url.r2.dev

# Nome do bucket que criou
R2_BUCKET_NAME=your_bucket_name

# Add this line for client-side access
NEXT_PUBLIC_R2_IMAGES_URL=https://your_public_bucket_url.r2.dev/teamaction-images

# ADMIN ACCESS (server-side only)
ADMIN_LOGIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash
ADMIN_SESSION_SECRET=replace_with_long_random_secret

# Admin credentials
ADMIN_LOGIN_PASSWORD_HASH=your_bcrypt_hashed_password_here
ADMIN_SESSION_SECRET=your_admin_session_secret_here